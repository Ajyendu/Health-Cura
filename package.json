{
  "name": "healthcare-app",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "start": "npm --prefix backend start",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "postinstall": "npm install --prefix frontend --include=dev && npm install --prefix backend",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "frontend": "npm --prefix frontend run dev",
    "backend": "npm --prefix backend run dev",
    "build": "npm install --prefix frontend --include=dev && npm --prefix frontend run build",
    "lint": "npm --prefix frontend run lint",
    "test:backend": "npm --prefix backend test",
    "seed:doctors": "npm --prefix backend run seed:doctors",
    "seed:nearby-doctors": "npm --prefix backend run seed:nearby-doctors",
    "verify": "npm run lint && npm run build && npm run test:backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
