NODE_ENV=development
PORT=8005
# Local: Docker `npm run db:up` or mongod on 27017.
# Render / production: required — use Render MongoDB, Atlas, etc. (no DB on 127.0.0.1 in the cloud).
MONGO_URI=mongodb://127.0.0.1:27017/healthcare-app
JWT_SECRET=replace_with_secure_secret
# Browser origin for CORS + cookies. Production: your static site URL (e.g. https://your-app.onrender.com).
FRONTEND_ORIGIN=http://localhost:5173
RECORDS_UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_BYTES=10485760
